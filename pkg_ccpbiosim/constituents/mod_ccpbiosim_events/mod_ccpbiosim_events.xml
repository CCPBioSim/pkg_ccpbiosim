<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
  <name>MOD_CCPBIOSIM_EVENTS</name>
  <version>1.0.7</version>
  <author>James Gebbie-Rayet</author>
  <creationDate>2026/04/27</creationDate>
  <description>MOD_CCPBIOSIM_EVENTS_DESC</description>
  <namespace path="src">CCPBioSim\Module\Events</namespace>
  <files>
    <folder module="mod_ccpbiosim_events">services</folder>
    <folder>src</folder>
    <folder>tmpl</folder>
    <folder>language</folder>
  </files>
  <languages>
    <language tag="en-GB">language/en-GB/mod_ccpbiosim_events.ini</language>
    <language tag="en-GB">language/en-GB/mod_ccpbiosim_events.sys.ini</language>
  </languages>
  <config>
    <fields name="params">
      <fieldset name="basic">
        <field name="count" type="number" label="MOD_CCPBIOSIM_EVENTS_PARAM_COUNT_LABEL" description="MOD_CCPBIOSIM_EVENTS_PARAM_COUNT_DESC" default="5" min="1" max="20" filter="integer"/>
        <field name="show_location" type="radio" label="MOD_CCPBIOSIM_EVENTS_PARAM_SHOW_LOCATION_LABEL" description="MOD_CCPBIOSIM_EVENTS_PARAM_SHOW_LOCATION_DESC" default="1" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
        <field name="show_past" type="radio" label="MOD_CCPBIOSIM_EVENTS_PARAM_SHOW_PAST_LABEL" description="MOD_CCPBIOSIM_EVENTS_PARAM_SHOW_PAST_DESC" default="0" class="btn-group btn-group-yesno">
          <option value="1">JYES</option>
          <option value="0">JNO</option>
        </field>
      </fieldset>
    </fields>
  </config>
</extension>
